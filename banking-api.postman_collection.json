{
  "info": {
    "name": "Banking API",
    "_postman_id": "banking-api-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"joe@example.com\",\n  \"password\": \"Secret123!\",\n  \"firstName\": \"Joe\",\n  \"lastName\": \"Davtian\",\n  \"bsn\": \"123456789\",\n  \"phoneNumber\": \"0612345678\"\n}"
            },
            "description": "Registration password must be at least 8 characters and include uppercase, lowercase, and special characters."
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"email\": \"alice@example.nl\",\n  \"password\": \"Pass123!\"\n}"
            },
            "description": "Seeded demo credentials: admin@bank.nl / Admin123!, alice@example.nl / Pass123!, bob@example.nl / Pass123!, charlie@example.nl / Charlie123!"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "pm.collectionVariables.set(\"accessToken\", response.accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "Current User (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Get All Customers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/customers?status=ACTIVE&search=",
              "host": ["{{baseUrl}}"],
              "path": ["customers"],
              "query": [
                { "key": "status", "value": "ACTIVE", "description": "PENDING | ACTIVE | CLOSED" },
                { "key": "search", "value": "", "description": "Search by name or email" }
              ]
            }
          }
        },
        {
          "name": "Get Customer by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/customers/1",
              "host": ["{{baseUrl}}"],
              "path": ["customers", "1"]
            }
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/customers/1",
              "host": ["{{baseUrl}}"],
              "path": ["customers", "1"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"status\": \"ACTIVE\",\n  \"firstName\": \"Joe\",\n  \"lastName\": \"Davtian\",\n  \"phoneNumber\": \"0612345678\",\n  \"absoluteTransferLimit\": 1000.00,\n  \"dailyTransferLimit\": 500.00\n}"
            }
          }
        },
        {
          "name": "Get Customer Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/customers/1/transactions?type=&minAmount=&maxAmount=&startDate=&endDate=",
              "host": ["{{baseUrl}}"],
              "path": ["customers", "1", "transactions"],
              "query": [
                { "key": "type", "value": "", "description": "TRANSFER | DEPOSIT | WITHDRAWAL" },
                { "key": "minAmount", "value": "" },
                { "key": "maxAmount", "value": "" },
                { "key": "startDate", "value": "", "description": "YYYY-MM-DD, inclusive lower bound" },
                { "key": "endDate", "value": "", "description": "YYYY-MM-DD, inclusive upper bound" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        {
          "name": "Employee Account Search",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/accounts?userId=&type=&status=&iban=&name=",
              "host": ["{{baseUrl}}"],
              "path": ["accounts"],
              "query": [
                { "key": "userId", "value": "", "description": "Filter by user ID" },
                { "key": "type", "value": "", "description": "CHECKING | SAVINGS" },
                { "key": "status", "value": "", "description": "ACTIVE | CLOSED" },
                { "key": "iban", "value": "", "description": "Filter by exact IBAN" },
                { "key": "name", "value": "", "description": "Employee search by customer first name, last name, or email." }
              ]
            },
            "description": "Employee-only private account search. Customers should use /accounts/me or /accounts/transfer-targets."
          }
        },
        {
          "name": "My Accounts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/accounts/me",
              "host": ["{{baseUrl}}"],
              "path": ["accounts", "me"]
            },
            "description": "Active customer-only endpoint for the current customer's own accounts."
          }
        },
        {
          "name": "Transfer Target Search",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/accounts/transfer-targets?name=",
              "host": ["{{baseUrl}}"],
              "path": ["accounts", "transfer-targets"],
              "query": [
                { "key": "name", "value": "", "description": "Customer first or last name fragment. Returns only active checking accounts for other customers." }
              ]
            },
            "description": "Active customer-only public lookup. Response rows expose only iban, firstName, and lastName."
          }
        },
        {
          "name": "Update Account",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/accounts/NL01BANK1234567890",
              "host": ["{{baseUrl}}"],
              "path": ["accounts", "NL01BANK1234567890"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"absoluteTransferLimit\": 500.00,\n  \"dailyTransferLimit\": 200.00,\n  \"status\": \"ACTIVE\"\n}"
            },
            "description": "At least one field must be provided. Setting status to CLOSED requires a zero balance."
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/transactions?iban=&type=&minAmount=&maxAmount=&startDate=&endDate=",
              "host": ["{{baseUrl}}"],
              "path": ["transactions"],
              "query": [
                { "key": "iban", "value": "" },
                { "key": "type", "value": "", "description": "TRANSFER | DEPOSIT | WITHDRAWAL" },
                { "key": "minAmount", "value": "" },
                { "key": "maxAmount", "value": "" },
                { "key": "startDate", "value": "", "description": "YYYY-MM-DD, inclusive lower bound" },
                { "key": "endDate", "value": "", "description": "YYYY-MM-DD, inclusive upper bound" }
              ]
            }
          }
        },
        {
          "name": "Create Transaction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["transactions"]
            },
            "body": {
              "mode": "raw",
              "options": { "raw": { "language": "json" } },
              "raw": "{\n  \"fromIban\": \"NL01BANK0000000001\",\n  \"toIban\": \"NL01BANK0000000003\",\n  \"amount\": 100.00,\n  \"type\": \"TRANSFER\",\n  \"description\": \"Rent payment\"\n}"
            },
            "description": "Customers must be ACTIVE. External customer transfers must target a CHECKING account. Daily outgoing limits count TRANSFER and WITHDRAWAL transactions."
          }
        }
      ]
    }
  ]
}
